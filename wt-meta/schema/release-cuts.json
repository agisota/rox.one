{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rox.one/schemas/wt-meta/release-cuts.json",
  "title": "ReleaseCuts",
  "description": "Release-cut topology that orders parallel WT delivery from foundation → ai.",
  "type": "object",
  "additionalProperties": false,
  "required": ["cuts"],
  "properties": {
    "cuts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "target_date", "includes", "excludes"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable release cut identifier (e.g. foundation, data, ui)."
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "target_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "foundation", "infra", "data", "platform", "ui", "sharing", "ai",
                "auth", "notifications", "storage", "agent", "sources"
              ]
            }
          },
          "excludes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
