{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@config/*": ["../../packages/shared/src/config/*"],
      "@rox-one/core": ["../../packages/core/src/index.ts"],
      "@rox-one/core/types": ["../../packages/core/src/types/index.ts"],
      "@rox-one/core/*": ["../../packages/core/src/*"],
      "@rox-one/session-tools-core": ["../../packages/session-tools-core/src/index.ts"],
      "@rox-one/session-tools-core/*": ["../../packages/session-tools-core/src/*"],
      "@rox-one/server-core": ["../../packages/server-core/src/index.ts"],
      "@rox-one/server-core/transport": ["../../packages/server-core/src/transport/index.ts"],
      "@rox-one/server-core/runtime": ["../../packages/server-core/src/runtime/index.ts"],
      "@rox-one/server-core/handlers": ["../../packages/server-core/src/handlers/index.ts"],
      "@rox-one/server-core/handlers/rpc": ["../../packages/server-core/src/handlers/rpc/index.ts"],
      "@rox-one/server-core/handlers/rpc/*": ["../../packages/server-core/src/handlers/rpc/*.ts"],
      "@rox-one/server-core/domain": ["../../packages/server-core/src/domain/index.ts"],
      "@rox-one/server-core/services": ["../../packages/server-core/src/services/index.ts"],
      "@rox-one/server-core/sessions": ["../../packages/server-core/src/sessions/index.ts"],
      "@rox-one/server-core/*": ["../../packages/server-core/src/*"],
      "@rox-one/messaging-gateway": ["../../packages/messaging-gateway/src/index.ts"],
      "@rox-one/messaging-gateway/*": ["../../packages/messaging-gateway/src/*"],
      "@rox-one/messaging-whatsapp-worker": ["../../packages/messaging-whatsapp-worker/src/protocol.ts"],
      "@rox-one/messaging-whatsapp-worker/*": ["../../packages/messaging-whatsapp-worker/src/*"],
      "@rox-one/shared": ["../../packages/shared/src/index.ts"],
      "@rox-one/shared/agent/modes": ["../../packages/shared/src/agent/mode-types.ts"],
      "@rox-one/shared/agent/mode-types": ["../../packages/shared/src/agent/mode-types.ts"],
      "@rox-one/shared/interceptor": ["../../packages/shared/src/interceptor-common.ts"],
      "@rox-one/ui": ["../../packages/ui/src/index.ts"],
      "@rox-one/ui/chat": ["../../packages/ui/src/components/chat/index.ts"],
      "@rox-one/ui/chat/turn-utils": ["../../packages/ui/src/components/chat/turn-utils.ts"],
      "@rox-one/ui/chat/*": ["../../packages/ui/src/components/chat/*"],
      "@rox-one/ui/markdown": ["../../packages/ui/src/components/markdown/index.ts"],
      "@rox-one/ui/annotations/follow-up-state": ["../../packages/ui/src/components/annotations/follow-up-state.ts"],
      "@rox-one/ui/context": ["../../packages/ui/src/context/index.ts"],
      "@rox-one/ui/*": ["../../packages/ui/src/*"],
      "@rox-one/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
