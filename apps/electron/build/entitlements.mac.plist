<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Hardened runtime entitlements for ROX.ONE private/RC macOS builds.
         Boundary contract: M.18 T250 (see docs/release/mac-trust-boundary-audit.md).
         These entitlements are intentionally minimal:
           - Allow JIT (V8 needs it).
           - Allow unsigned-executable-memory (Electron renderer JIT pages).
           - Allow outbound network (LLM provider HTTPS calls).
         Explicitly NOT granted:
           - com.apple.security.cs.disable-library-validation: dropped in T250
             so the OS enforces signed-only dylib loads inside the app bundle.
           - com.apple.security.network.server: never required for a desktop client.
           - com.apple.security.cs.allow-dyld-environment-variables: never needed.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
  </dict>
</plist>
