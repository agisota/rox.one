#!/usr/bin/env sh
# Husky v9.1 user-shim layout: the dispatcher at .husky/_/<hookname> calls
# `sh -e .husky/<hookname>`, so this file is plain shell with no source line.
# (The deprecated `. "$(dirname -- "$0")/_/husky.sh"` form is removed in
# husky v10; we keep this file forward-compatible.)

# T507 — Gitleaks scan (RC2)
# Scans staged changes for secrets BEFORE they enter git history.
# Developers without gitleaks are NOT blocked locally (best-effort/fail-open).
# Hosted CI secret-scan stays the hard gate via .github/workflows/secret-scan.yml.
# Install: brew install gitleaks (mac) or apt install gitleaks (linux).
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --no-banner
else
  echo "[pre-commit] gitleaks not installed; skipping secret scan."
  echo "[pre-commit] Install: brew install gitleaks (mac) or apt install gitleaks (linux)."
fi
