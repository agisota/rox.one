{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "dependencyDashboardApproval": true,
  "minimumReleaseAge": "7 days",
  "packageRules": [
    { "matchUpdateTypes": ["major"], "automerge": false, "labels": ["dependencies", "major"] },
    { "matchUpdateTypes": ["minor", "patch"], "automerge": false },
    {
      "description": "Keep GitHub Actions SHA-pinned with a # version comment (preserves the supply-chain hardening pattern set in workflows).",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "extractVersion": "^v(?<version>.+)$"
    }
  ],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 6,
  "rangeStrategy": "pin"
}
