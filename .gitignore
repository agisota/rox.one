# Lock files from other package managers
pnpm-lock.yaml

# ROX local data (sessions, credentials, config)
.rox/

# Rox Design runtime payload (~251MB Open Design 0.7.0 bundle).
# Generated locally / at release time by `bun run rox-design:prepare`.
# Keep README.md committed so the bootstrap workflow stays discoverable.
apps/electron/resources/rox-design/*
!apps/electron/resources/rox-design/README.md
!apps/electron/resources/rox-design/NOTICES.md

# SSH keys and secrets
*.pem
*.key
sshkey
id_rsa*
id_ed25519*

# Credentials files
credentials.enc
*.credentials

# act (local GitHub Actions runner)
.secrets
.actrc

# Audit harness raw run artifacts (committed: docs/tickets, docs/audits/INDEX.md only)
/audits/
!docs/audits/

# Rendered wrangler configs (regenerated from .example.toml at deploy time)
infra/cloudflare/wrangler.rox-one-release-feed.toml
infra/cloudflare/wrangler.rox-one.toml
