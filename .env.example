# =============================================================================
# ROX.ONE environment variables (canonical names)
#
# Phase R.6 of the ROX.ONE rebrand standardised these 16 variables under the
# `ROX_*` prefix. The legacy `ROX_*` names are still honored at runtime via
# the readEnv() shim for one minor version; please migrate to ROX_*.
#
# ROX_SERVER_TOKEN          — bearer token for clients connecting to the WS RPC server
# ROX_SERVER_URL            — ws:// or wss:// URL used by thin-client Electron / CLI
# ROX_RPC_HOST              — WS RPC bind address (default 127.0.0.1)
# ROX_RPC_PORT              — WS RPC bind port (default 9100)
# ROX_RPC_TLS_CERT          — PEM cert for wss:// listener
# ROX_RPC_TLS_KEY           — PEM key for wss:// listener (required with cert)
# ROX_RPC_TLS_CA            — optional PEM CA bundle for client cert verification
# ROX_TLS_CA                — optional PEM CA bundle for the CLI / Electron client
# ROX_DEBUG                 — set to '1' or 'true' to enable debug logging
# ROX_DEV_RUNTIME           — set to '1' to enable the dev-mode runtime resolver walk-up
# ROX_BUNDLED_ASSETS_ROOT   — override the bundled-assets root (defaults to cwd)
# ROX_WEBUI_DIR             — path to built WebUI assets (enables /webui on the RPC port)
# ROX_WEBUI_PORT            — optional WebUI port override
# ROX_MESSAGING_WA_WORKER   — path to WhatsApp worker entry point
# ROX_MESSAGING_NODE_BIN    — node binary used to spawn the messaging worker (default 'node')
# ROX_CONFIG_DIR            — override the ROX config directory (default ~/.rox)
# =============================================================================

# Required: Anthropic API Key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Required: Rox MCP Server URL
# Format: http://localhost:3000/v1/links/{secretLinkId}/mcp
ROX_MCP_URL=http://localhost:3000/v1/links/YOUR_SECRET_LINK_ID/mcp

# Required: Bearer token for MCP authentication
ROX_MCP_TOKEN=your-bearer-token-here

# Google OAuth Configuration (OPTIONAL - for development/testing only)
# For production use, users should provide their own credentials via source configuration.
# These env vars serve as a fallback if source config doesn't specify credentials.
# See README_FOR_OSS.md for setup instructions.
# To create credentials: Google Cloud Console > APIs & Services > Credentials > Desktop app
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Slack OAuth Configuration (for Slack workspace integration)
# Get these from Slack API > Your Apps > OAuth & Permissions
SLACK_OAUTH_CLIENT_ID=your-slack-client-id
SLACK_OAUTH_CLIENT_SECRET=your-slack-client-secret

# Microsoft OAuth Configuration (for Outlook, OneDrive, Teams integration)
# Get these from Azure Portal > App Registrations
# Note: Create a "Mobile and desktop applications" platform OAuth client - PKCE is used so no client_secret is needed
MICROSOFT_OAUTH_CLIENT_ID=your-microsoft-client-id

# Sentry Error Tracking (captures crashes and chat/SDK errors)
# Get the ingest URL from Sentry > Project Settings > Client Keys (DSN)
SENTRY_ELECTRON_INGEST_URL=https://your-public-key@o0.ingest.sentry.io/0
ROX_DATABASE_URL=postgres://rox_one:change-me@localhost:5432/rox_one
ROX_AUTH_JWT_SECRET=change-me-with-a-strong-random-secret
ROX_SIGNUP_ENABLED=true
ROX_PUBLIC_APP_URL=https://rox.one
RESEND_API_KEY=re_...
ROX_EMAIL_FROM="ROX ONE <noreply@rox.one>"
