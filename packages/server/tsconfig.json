{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@craft-agent/shared": ["../shared/src/index.ts"],
      "@craft-agent/shared/*": ["../shared/src/*"],
      "@craft-agent/server-core": ["../server-core/src/index.ts"],
      "@craft-agent/server-core/*": ["../server-core/src/*"],
      "@rox-one/core": ["../core/src/index.ts"],
      "@rox-one/core/*": ["../core/src/*"]
    }
  },
  "include": ["src/**/*", "../shared/src/agent/bash-parser.d.ts"],
  "exclude": ["node_modules", "dist"]
}
