{
  "name": "@rox-agent/server",
  "version": "0.8.0",
  "description": "Standalone headless Rox Agent server (Bun runtime)",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "rox-server": "src/index.ts"
  },
  "files": [
    "src/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": {
    "name": "Rox Docs Ltd.",
    "email": "support@rox.do"
  },
  "license": "MIT",
  "homepage": "https://agents.rox.do",
  "scripts": {
    "start": "bun run src/index.ts",
    "generate-token": "bun run src/index.ts --generate-token",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rox-agent/core": "workspace:*",
    "@rox-agent/server-core": "workspace:*",
    "@rox-agent/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0",
    "ws": "^8.16.0"
  }
}
