{
  "name": "@rox-one/server",
  "version": "0.9.1",
  "description": "Standalone headless ROX server (Bun runtime)",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "rox-server": "src/index.ts"
  },
  "files": [
    "src/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": {
    "name": "roxone",
    "email": "support@rox.one"
  },
  "license": "Apache-2.0",
  "homepage": "https://app.rox.one",
  "scripts": {
    "start": "bun run src/index.ts",
    "generate-token": "bun run src/index.ts --generate-token",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rox-one/core": "workspace:*",
    "@rox-one/messaging-gateway": "workspace:*",
    "@rox-one/server-core": "workspace:*",
    "@rox-one/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2",
    "ws": "8.20.0"
  }
}
