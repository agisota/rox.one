{
  "name": "@rox-one/server-core",
  "version": "0.9.1",
  "license": "Apache-2.0",
  "description": "Reusable headless server infrastructure for ROX",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./transport": "./src/transport/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./handlers": "./src/handlers/index.ts",
    "./bootstrap": "./src/bootstrap/index.ts",
    "./model-fetchers": "./src/model-fetchers/index.ts",
    "./domain": "./src/domain/index.ts",
    "./services": "./src/services/index.ts",
    "./handlers/rpc": "./src/handlers/rpc/index.ts",
    "./handlers/rpc/*": "./src/handlers/rpc/*.ts",
    "./audit": "./src/audit/index.ts",
    "./sessions": "./src/sessions/index.ts",
    "./webui": "./src/webui/index.ts",
    "./accounts": "./src/accounts/index.ts",
    "./sync": "./src/sync/index.ts",
    "./persistence": "./src/persistence/index.ts",
    "./mission-scheduler": "./src/mission-scheduler/index.ts",
    "./provider-gateway": "./src/provider-gateway/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rox-one/core": "workspace:*",
    "@rox-agent/shared": "workspace:*",
    "@mariozechner/pi-ai": "0.72.1",
    "jose": "^6.0.0",
    "pg": "^8.20.0",
    "sharp": "0.34.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.2"
  }
}
