{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@rox-one/core": ["../core/src/index.ts"],
      "@rox-one/core/types": ["../core/src/types/index.ts"],
      "@rox-one/core/*": ["../core/src/*"],
      "@rox-one/session-tools-core": ["../session-tools-core/src/index.ts"],
      "@rox-one/session-tools-core/*": ["../session-tools-core/src/*"],
      "@rox-one/shared": ["../shared/src/index.ts"],
      "@rox-one/shared/interceptor": ["../shared/src/interceptor-common.ts"],
      "@rox-one/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "../shared/src/agent/bash-parser.d.ts"],
  "exclude": ["node_modules", "dist"]
}
