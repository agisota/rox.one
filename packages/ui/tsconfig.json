{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "rootDir": "../..",
    "paths": {
      "@rox-one/core": ["../core/src/index.ts"],
      "@rox-one/core/types": ["../core/src/types/index.ts"],
      "@rox-one/core/*": ["../core/src/*"],
      "@rox-one/shared": ["../shared/src/index.ts"],
      "@rox-one/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/__tests__"]
}
